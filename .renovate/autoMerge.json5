{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto-merge GitHub Actions (digest, patch, minor)",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
      matchManagers: ["github-actions"],
      matchUpdateTypes: [
        "digest",
        "patch",
        "minor",
      ],
      minimumReleaseAge: "3 days",
    },
    {
      description: "Auto-merge trusted GitHub Actions (digest, patch, minor)",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
      matchManagers: ["github-actions"],
      matchPackageNames: [
        "/^actions\\//",
        "/^renovatebot\\//",
      ],
      matchUpdateTypes: [
        "digest",
        "patch",
        "minor",
      ],
      minimumReleaseAge: "1 minute",
    },
    {
      description: "Auto-merge trusted OCI Charts (digest)",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      matchDatasources: ["docker"],
      matchPackageNames: ["/home-operations/"],
      matchUpdateTypes: ["digest"],
    },
    {
      description: "Auto-merge high-cadence OCI Charts (patch, minor)",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/kube-prometheus-stack/",
      ],
      matchUpdateTypes: [
        "patch",
        "minor",
      ],
      schedule: ["before 6am on Monday"],
    },
    {
      description: "Auto-merge Grafana dashboard revisions",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
      matchDatasources: ["custom.grafana-dashboards"],
      matchUpdateTypes: ["major"],
    },
    {
      description: "Auto-merge Renovate Presets",
      addLabels: ["action/automerge"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
      matchManagers: ["renovate-config"],
      matchUpdateTypes: [
        "patch",
        "minor",
      ],
    },
  ],
}
