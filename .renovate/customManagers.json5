{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      description: "Process annotated dependencies",
      customType: "regex",
      managerFilePatterns: [
        "/\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        // # renovate: datasource=github-releases depName=foo/bar
        // foobar_version: v1.0.0
        // # renovate: datasource=docker depName=ghcr.io/foo/bar
        // FOOBAR_VERSION=v1.0.0
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n.+(:\\s|=)(&\\S+\\s)?(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
    {
      description: "Process OCI dependencies",
      customType: "regex",
      managerFilePatterns: [
        "/\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "oci://(?<depName>[^:]+):(?<currentValue>\\S+)",
      ],
      datasourceTemplate: "docker",
    },
    {
      description: "Process any repository keys in YAML files",
      customType: "regex",
      managerFilePatterns: [
        "/\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "repository: (?<depName>[^\\s:]+):(?<currentValue>\\S+)(@(?<currentDigest>sha256:\\S+)?)",
      ],
      datasourceTemplate: "docker",
    },
    {
      description: "Process any imageName keys in YAML files",
      customType: "regex",
      managerFilePatterns: [
        "/\\.yaml(?:\\.j2)?$/",
      ],
      matchStrings: [
        "imageName: (?<depName>[^\\s:]+):(?<currentValue>\\S+)(@(?<currentDigest>sha256:\\S+)?)",
      ],
      datasourceTemplate: "docker",
    }
  ],
}
